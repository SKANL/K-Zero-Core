# ==========================================
# CONFIGURACIÓN CORE DE K-ZERO-CORE
# ==========================================

# Directorio donde se guardarán sesiones, prompts, transcripciones y base de datos vectorial.
# Si no se define, se usa la carpeta del usuario (~/.k_zero).
K_ZERO_DATA_DIR=C:/tu/ruta/al/proyecto/data

# ==========================================
# CONFIGURACIÓN OLLAMA (Local)
# ==========================================

# URL de tu instancia de Ollama.
# Solo es necesario cambiarlo si Ollama corre en otro puerto o PC.
OLLAMA_HOST=http://localhost:11434

# ==========================================
# CONFIGURACIÓN STT (Speech-to-Text / Whisper)
# ==========================================

# Tamaño del modelo faster-whisper. Opciones: tiny | base | small | medium | large-v3
# Recomendado: 'small' para uso general. 'medium' para mayor precisión. 'large-v3' para máxima calidad.
# Nota: modelos más grandes requieren más RAM/VRAM y son más lentos en CPU.
STT_MODEL_SIZE=small

# Idioma de transcripción en código ISO-639-1.
# Especificar el idioma mejora la velocidad y precisión significativamente.
# Usar 'auto' o 'none' para autodetección (mayor latencia).
# Ejemplos: es | en | fr | de | pt
STT_LANGUAGE=es

# Sensibilidad del VAD (Voice Activity Detection) de Silero. Rango: 0.0 - 1.0
# Valor más alto = más estricto (descarta más segmentos ambiguos).
# 0.5 es el valor óptimo recomendado. Aumentar a 0.7-0.8 en entornos ruidosos.
STT_VAD_THRESHOLD=0.5

# Umbral de energía de SpeechRecognition para detectar inicio de habla.
# Valor más bajo = más sensible al ruido. Rango típico: 100-500.
STT_ENERGY_THRESHOLD=300

# ==========================================
# CONFIGURACIÓN TTS (Text-to-Speech / edge-tts)
# ==========================================

# Voz de Microsoft edge-tts a usar por defecto.
# Ver lista completa con: edge-tts --list-voices
# Ejemplos: es-MX-DaliaNeural | es-ES-ElviraNeural | en-US-JennyNeural
TTS_VOICE=es-MX-DaliaNeural
